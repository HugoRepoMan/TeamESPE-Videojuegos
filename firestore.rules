rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (request.auth.token.admin == true || request.auth.token.email == 'admin@teamespe.com');
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Public settings - anyone can read
    match /settings/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users - read/write own profile only
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['roleVisible'])
        && request.resource.data.displayName is string
        && request.resource.data.email is string;
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email', 'roleVisible', 'createdAt']);
      // Admin can read all users
      allow read: if isAdmin();
    }

    // Disciplines - public read, admin write
    match /disciplines/{disciplineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Registrations
    match /registrations/{registrationId} {
      // Users can read their own registrations
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Users can create registrations under their own ID with enforced constraints.
      // The document ID must follow the pattern {userId}_{disciplineId} to guarantee uniqueness per user per discipline.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && registrationId.matches(request.auth.uid + '_.*')
        && request.resource.data.paymentStatus == 'pending'
        && request.resource.data.amount == 2
        && request.resource.data.keys().hasAll(['userId', 'disciplineId', 'playerNick', 'paymentStatus', 'amount']);

      // Users cannot overwrite an already-reviewed registration (approved/rejected).
      // This prevents re-submitting after a payment decision has been made.
      allow update: if request.auth != null &&
        (
          // Admin can always update
          isAdmin()
          // Users can only update their own pending registrations (e.g. to re-upload receipt)
          // but cannot change paymentStatus, amount, userId or disciplineId.
          || (
            request.auth.uid == resource.data.userId
            && resource.data.paymentStatus == 'pending'
            && request.resource.data.paymentStatus == 'pending'
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'disciplineId', 'amount', 'createdAt'])
          )
        );

      // Only admin can delete registrations
      allow delete: if isAdmin();
    }

    // Matches - public read for published, admin write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Treasury - admin only
    match /treasury/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
