rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Public settings - anyone can read
    match /settings/public {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Users - read/write own profile only
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['roleVisible'])
        && request.resource.data.displayName is string
        && request.resource.data.email is string;
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email', 'roleVisible', 'createdAt']);
      // Admin can read all users
      allow read: if request.auth != null && request.auth.token.admin == true;
    }

    // Disciplines - public read, admin write
    match /disciplines/{disciplineId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Registrations
    match /registrations/{registrationId} {
      // Users can read their own registrations
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      // Users can create registrations (but not set paymentStatus to approved)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.paymentStatus == 'pending'
        && request.resource.data.amount == 2;
      // Only admin can update (especially paymentStatus)
      allow update: if request.auth != null && request.auth.token.admin == true;
    }

    // Matches - public read for published, admin write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Treasury - admin only
    match /treasury/{docId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
